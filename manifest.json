{
  "manifest_version": 3,
  "name": "YouTube Extras",
  "version": "1.0",
  "description": "Extra keyboard shortcuts for YouTube",
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "css": ["styles/badge.css", "styles/tooltip.css", "styles/search.css"],
      "js": [
        "modules/youtubeSelectors.js",
        "modules/shortcuts.js",
        "modules/shortcutCore.js",
        "modules/search.js",
        "modules/playerShortcuts.js",
        "modules/subtitleSearch.js",
        "modules/debugAutoHide.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
